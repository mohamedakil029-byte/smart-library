# Environment Configuration Template

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True

# Database Configuration
# SQLite (Development)
DATABASE_URL=sqlite:///library_requests.db

# PostgreSQL (Production Example)
# DATABASE_URL=postgresql://user:password@localhost:5432/library_requests

# MySQL (Production Example)
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/library_requests

# Application Settings
SECRET_KEY=your-secret-key-here-change-in-production
SESSION_COOKIE_SECURE=False

# ServiceNow Integration
SERVICENOW_URL=https://dev.service-now.com
SERVICENOW_USER=integration_user
SERVICENOW_PASS=integration_password

# Notification Settings
NOTIFICATION_ENABLED=True
ADMIN_EMAIL=admin@library.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_email_password

# Request Configuration
REQUEST_TIMEOUT_DAYS=30
APPROVAL_REQUIRED_THRESHOLD=5
HIGH_PRIORITY_THRESHOLD=2
HIGH_BUDGET_THRESHOLD=10000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# API Configuration
API_HOST=0.0.0.0
API_PORT=5000
API_DEBUG=True

# Security
ALLOW_CORS=False
CORS_ORIGINS=http://localhost:3000

# Feature Flags
ENABLE_ANALYTICS=True
ENABLE_NOTIFICATIONS=True
ENABLE_SERVICENOW_SYNC=False
